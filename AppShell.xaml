<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="DriverLedger.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DriverLedger.Views"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <!--
        Top-level Shell routes — navigable with absolute // routes.
        SplashPage is the very first page shown on cold launch.
        StartupService routes away from it immediately.
    -->
    <ShellContent Title="Splash"           Route="SplashPage"           ContentTemplate="{DataTemplate views:SplashPage}" />
    <ShellContent Title="CompanyCreation"  Route="CompanyCreationPage"  ContentTemplate="{DataTemplate views:CompanyCreationPage}" />
    <ShellContent Title="Login"            Route="LoginPage"            ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Title="Dashboard"        Route="DashboardPage"        ContentTemplate="{DataTemplate views:DashboardPage}" />
    <!-- Legacy company page route kept for backwards compat -->
    <ShellContent Title="Company"          Route="CompanyPage"          ContentTemplate="{DataTemplate views:CompanyPage}" />

</Shell>
