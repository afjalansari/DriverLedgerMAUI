<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DriverLedger.Views.ForgotPasswordPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D1B2A">

    <ContentPage.Resources>
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextColor" Value="#90A4AE"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ErrorLabel" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="#FF5252"/>
            <Setter Property="Margin" Value="4,2,0,0"/>
        </Style>
        <Style x:Key="FieldEntry" TargetType="Entry">
            <Setter Property="BackgroundColor" Value="#243447"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="PlaceholderColor" Value="#90A4AE"/>
            <Setter Property="HeightRequest" Value="52"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid x:Name="RootGrid" MinimumHeightRequest="600" RowDefinitions="Auto,*,Auto">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPageTapped"/>
            </Grid.GestureRecognizers>

            <!-- ── Header ───────────────────────────────────────────── -->
            <VerticalStackLayout Grid.Row="0" Spacing="8"
                                 HorizontalOptions="Fill"
                                 Padding="20,52,20,24">

                <!-- Back button row -->
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Text="← Back"
                            Command="{Binding BackToLoginCommand}"
                            TextColor="#90A4AE"
                            BackgroundColor="Transparent"
                            FontSize="14"
                            HorizontalOptions="Start"
                            VerticalOptions="Center"/>
                </Grid>

                <Label Text="Reset Your Password"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Start"/>
                <Label Text="Enter your registered mobile number to reset your password"
                       FontSize="13" TextColor="#90A4AE" HorizontalOptions="Start"/>
            </VerticalStackLayout>

            <!-- ── Form Card ─────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    BackgroundColor="#1A2C3D"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#243447"
                    StrokeThickness="1"
                    Padding="24"
                    Margin="20,0,20,24">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.35"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">

                    <!-- Mobile Number -->
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Registered Mobile Number" Style="{StaticResource FieldLabel}"/>
                        <Border BackgroundColor="#243447" StrokeShape="RoundRectangle 10"
                                Stroke="#2979FF" StrokeThickness="1" Padding="14,0">
                            <Entry x:Name="EntryMobile"
                                   Text="{Binding MobileNumber}"
                                   Placeholder="+91 9999 999999"
                                   Keyboard="Telephone"
                                   Style="{StaticResource FieldEntry}"
                                   ReturnType="Next"
                                   ReturnCommand="{Binding FocusNewPasswordCommand}"/>
                        </Border>
                        <Label Text="{Binding MobileNumberError}"
                               Style="{StaticResource ErrorLabel}"
                               IsVisible="{Binding HasMobileError}"/>
                    </VerticalStackLayout>

                    <!-- New Password -->
                    <VerticalStackLayout Spacing="0">
                        <Label Text="New Password" Style="{StaticResource FieldLabel}"/>
                        <Border BackgroundColor="#243447" StrokeShape="RoundRectangle 10"
                                Stroke="#2979FF" StrokeThickness="1" Padding="14,0">
                            <Entry x:Name="EntryNewPassword"
                                   Text="{Binding NewPassword}"
                                   Placeholder="Min 8 chars, 1 uppercase, 1 digit"
                                   IsPassword="True"
                                   Style="{StaticResource FieldEntry}"
                                   ReturnType="Next"
                                   ReturnCommand="{Binding FocusConfirmPasswordCommand}"/>
                        </Border>
                        <Label Text="{Binding NewPasswordError}"
                               Style="{StaticResource ErrorLabel}"
                               IsVisible="{Binding HasNewPasswordError}"/>
                    </VerticalStackLayout>

                    <!-- Confirm New Password -->
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Confirm New Password" Style="{StaticResource FieldLabel}"/>
                        <Border BackgroundColor="#243447" StrokeShape="RoundRectangle 10"
                                Stroke="#2979FF" StrokeThickness="1" Padding="14,0">
                            <Entry x:Name="EntryConfirmPassword"
                                   Text="{Binding ConfirmPassword}"
                                   Placeholder="Re-enter new password"
                                   IsPassword="True"
                                   Style="{StaticResource FieldEntry}"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding ResetCommand}"/>
                        </Border>
                        <Label Text="{Binding ConfirmPasswordError}"
                               Style="{StaticResource ErrorLabel}"
                               IsVisible="{Binding HasConfirmPasswordError}"/>
                    </VerticalStackLayout>

                    <!-- Reset Password Button -->
                    <Button Text="Reset Password"
                            Command="{Binding ResetCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            TextColor="White"
                            BackgroundColor="#2979FF"
                            Margin="0,8,0,0"/>

                    <!-- Activity Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#2979FF"
                                       HorizontalOptions="Center"/>

                    <!-- Back to Login ghost button -->
                    <Button Text="Back to Login"
                            Command="{Binding BackToLoginCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="44"
                            FontSize="14"
                            TextColor="#90A4AE"
                            BackgroundColor="Transparent"
                            BorderColor="#37474F"
                            BorderWidth="1"
                            CornerRadius="10"/>

                </VerticalStackLayout>
            </Border>

            <Label Grid.Row="2"
                   Text="Offline • Secure • Fast"
                   FontSize="11" TextColor="#37474F"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

        </Grid>
    </ScrollView>

</ContentPage>
