<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DriverLedger.Views.DriverLedgerListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DriverLedger.ViewModels"
    xmlns:dto="clr-namespace:DriverLedger.DTOs"
    x:DataType="vm:DriverLedgerListViewModel"
    BackgroundColor="#080C18" Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BgPage">#080C18</Color>
            <Color x:Key="BgCard">#0D1426</Color>
            <Color x:Key="BorderCard">#161F30</Color>
            <Color x:Key="Green">#4CAF50</Color>
            <Color x:Key="Red">#EF5350</Color>
            <Color x:Key="Blue">#4A90D9</Color>
            <Color x:Key="Muted">#566A7F</Color>
            <Color x:Key="White">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- ═══════════════════════════════════════
             HEADER — Hero gradient bar
        ═══════════════════════════════════════ -->
        <Grid Grid.Row="0" Padding="20,50,20,18">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D2040" Offset="0"/>
                    <GradientStop Color="#080C18" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Grid.Column="0" Text="‹" FontSize="28" TextColor="{StaticResource White}" VerticalOptions="Center" Margin="0,0,12,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📒" FontSize="18"/>
                        <Label Text="Driver" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource White}"/>
                        <Label Text="Ledger" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Blue}"/>
                    </HorizontalStackLayout>
                    <Label Text="Sabhi drivers ka hisaab-kitaab" FontSize="11.5" TextColor="{StaticResource Muted}"/>
                </VerticalStackLayout>
                <Label Grid.Column="2" Text="{Binding PendingLabel}" FontSize="10" TextColor="{StaticResource Muted}" VerticalOptions="Center" HorizontalOptions="End"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════
             WALLET OVERVIEW CARD
        ═══════════════════════════════════════ -->
        <Border Grid.Row="1" BackgroundColor="#0D1426" StrokeShape="RoundRectangle 18" Stroke="#161F30" StrokeThickness="1.5" Padding="18,16" Margin="14,0,14,0">
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="14">

                <!-- Driver se lena (GREEN — drivers owe owner = negative balances) -->
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Label Text="Driver se Lena" FontSize="10" TextColor="{StaticResource Muted}" HorizontalOptions="Center"/>
                    <Label Text="Drivers owe you" FontSize="8" TextColor="#3A5570" HorizontalOptions="Center"/>
                    <HorizontalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="₹" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Green}" VerticalOptions="End" Margin="0,0,0,2"/>
                        <Label Text="{Binding TotalOwnerOwes, StringFormat='{0:N0}'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Green}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Divider -->
                <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#1E2A3F" VerticalOptions="Fill"/>

                <!-- Driver ko dena (RED — owner owes drivers = positive balances) -->
                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                    <Label Text="Driver ko Dena" FontSize="10" TextColor="{StaticResource Muted}" HorizontalOptions="Center"/>
                    <Label Text="You owe drivers" FontSize="8" TextColor="#3A5570" HorizontalOptions="Center"/>
                    <HorizontalStackLayout Spacing="2" HorizontalOptions="Center">
                        <Label Text="₹" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Red}" VerticalOptions="End" Margin="0,0,0,2"/>
                        <Label Text="{Binding TotalOwnerToGet, StringFormat='{0:N0}'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Red}"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════
             ACTION BUTTONS
        ═══════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10" Padding="14,12,14,0">
            <Button Grid.Column="0" Text="🔴  Advance Diya"
                    BackgroundColor="#1C0E00" TextColor="#FFA726" FontSize="13" FontAttributes="Bold"
                    CornerRadius="12" HeightRequest="46" BorderColor="#3A1E00" BorderWidth="1"
                    Command="{Binding AddAdvanceCommand}"/>
            <Button Grid.Column="1" Text="🟢  Payment Mila"
                    BackgroundColor="#071C10" TextColor="#4CAF50" FontSize="13" FontAttributes="Bold"
                    CornerRadius="12" HeightRequest="46" BorderColor="#153A20" BorderWidth="1"
                    Command="{Binding ReceivePaymentCommand}"/>
        </Grid>

        <!-- ═══════════════════════════════════════
             SEARCH BAR
        ═══════════════════════════════════════ -->
        <Border Grid.Row="3" BackgroundColor="#0D1426" StrokeShape="RoundRectangle 12" Stroke="#161F30" Margin="14,10,14,4" Padding="4,0">
            <SearchBar Text="{Binding SearchText}" Placeholder="Driver ka naam ya number dalo…" 
                       PlaceholderColor="#3A5570" TextColor="{StaticResource White}" 
                       BackgroundColor="Transparent" CancelButtonColor="{StaticResource Blue}"/>
        </Border>

        <!-- ═══════════════════════════════════════
             DRIVER LIST
        ═══════════════════════════════════════ -->
        <CollectionView Grid.Row="4" ItemsSource="{Binding DriverSummaries}" Margin="14,4,14,0" SelectionMode="None">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <Border BackgroundColor="#0D1426" StrokeShape="RoundRectangle 16" Stroke="#161F30" Padding="24,28">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📒" FontSize="42" HorizontalOptions="Center"/>
                        <Label Text="Koi driver nahi mila" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalOptions="Center"/>
                        <Label Text="Pehle driver add karo, phir ledger yahan dikhega" FontSize="12" TextColor="{StaticResource Muted}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:DriverBalanceSummary">
                    <Border BackgroundColor="#0D1426" StrokeShape="RoundRectangle 16" Stroke="#161F30" StrokeThickness="1" Padding="16,14">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DriverLedgerListViewModel}}, Path=ViewLedgerCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                            <!-- Status Dot -->
                            <Grid Grid.Column="0" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                                <Border BackgroundColor="{Binding StatusBadgeColor}" StrokeShape="RoundRectangle 22" 
                                        WidthRequest="44" HeightRequest="44">
                                    <Label Text="👤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <!-- Live status dot -->
                                <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6"
                                         BackgroundColor="{Binding StatusDotColor}" 
                                         HorizontalOptions="End" VerticalOptions="End" Margin="0,0,-2,-2"/>
                            </Grid>

                            <!-- Driver Info + Status -->
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding DriverName}" TextColor="White" FontSize="15" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding MobileNumber}" TextColor="#3A5570" FontSize="12"/>
                                <!-- Status badge -->
                                <Border BackgroundColor="{Binding StatusBadgeColor}" StrokeShape="RoundRectangle 8" Padding="8,3" HorizontalOptions="Start" Margin="0,2,0,0">
                                    <Label Text="{Binding StatusText}" FontSize="10" FontAttributes="Bold" TextColor="{Binding StatusBadgeTextColor}"/>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Balance Amount + Arrow -->
                            <VerticalStackLayout Grid.Column="2" Spacing="3" VerticalOptions="Center" HorizontalOptions="End">
                                <Label Text="{Binding BalanceDisplay}" FontSize="18" FontAttributes="Bold" TextColor="{Binding BalanceColor}" HorizontalOptions="End"/>
                                <Label Text="{Binding StatusTextEnglish}" FontSize="9" TextColor="{Binding StatusBadgeTextColor}" HorizontalOptions="End"/>
                                <Label Text="›" FontSize="18" TextColor="#3A5570" HorizontalOptions="End" Margin="0,-4,0,0"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ═══════════════════════════════════════
             ACTIVITY INDICATOR
        ═══════════════════════════════════════ -->
        <ActivityIndicator Grid.Row="5" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Blue}" HorizontalOptions="Center" Margin="0,8"/>
    </Grid>
</ContentPage>
