<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DriverLedger.Views.SettlementDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DriverLedger.ViewModels"
    x:DataType="vm:SettlementDetailViewModel"
    Title="{Binding Title}"
    BackgroundColor="#080C18"
    Shell.NavBarIsVisible="True">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BgCard">#0D1426</Color>
            <Color x:Key="BorderCard">#161F30</Color>
            <Color x:Key="BorderBlue">#1A3560</Color>
            <Color x:Key="Green">#4CAF50</Color>
            <Color x:Key="Red">#EF5350</Color>
            <Color x:Key="Blue">#4A90D9</Color>
            <Color x:Key="Orange">#FFA726</Color>
            <Color x:Key="Muted">#566A7F</Color>
            <Color x:Key="Dim">#3A5570</Color>
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="Teal">#00E5CC</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16,16,16,32">

            <!-- ① Summary Card (Visually Dominant) -->
            <Border StrokeShape="RoundRectangle 20" StrokeThickness="2" Padding="20,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A1830" Offset="0"/>
                        <GradientStop Color="#0D1426" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Stroke>
                    <SolidColorBrush Color="{Binding NetDriverPayable, Converter={StaticResource NetAmountToColorConverter}}"/>
                </Border.Stroke>

                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label Text="FINAL HISAAB" TextColor="{StaticResource Muted}" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                    
                    <Label Text="{Binding NetDriverPayable, StringFormat='₹{0:N0}'}" 
                           TextColor="{Binding NetDriverPayable, Converter={StaticResource NetAmountToColorConverter}}" 
                           FontSize="48" FontAttributes="Bold" HorizontalOptions="Center"/>
                    
                    <Label Text="{Binding SettlementLabel}" 
                           TextColor="{StaticResource White}" FontSize="18" FontAttributes="Bold" 
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderCard}" Margin="0,8"/>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Driver Name" TextColor="{StaticResource Muted}" FontSize="10"/>
                            <Label Text="{Binding DriverName}" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="End">
                            <Label Text="Vehicle Number" TextColor="{StaticResource Muted}" FontSize="10" HorizontalOptions="End"/>
                            <Label Text="{Binding VehicleNumber}" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold" HorizontalOptions="End"/>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ② Step-by-Step Hisaab Breakdown -->
            <Label Text="HISAAB KI DETAILS" TextColor="{StaticResource Muted}" FontSize="11" FontAttributes="Bold" Margin="4,0"/>

            <!-- STEP 1: Total Income -->
            <Border BackgroundColor="{StaticResource BgCard}" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderCard}" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="1. Total Income (Kul Kamaai)" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="{Binding AggregatorSummary}" TextColor="{StaticResource Dim}" FontSize="10" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding TotalIncome, StringFormat='₹{0:N0}'}" TextColor="{StaticResource Green}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- STEP 2: Driver Share -->
            <Border BackgroundColor="{StaticResource BgCard}" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderCard}" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="2. Driver Share (Hissa)" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="50% of Total Income" TextColor="{StaticResource Dim}" FontSize="10"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding DriverShare, StringFormat='+ ₹{0:N0}'}" TextColor="{StaticResource Orange}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- STEP 3: Cash Liya -->
            <Border BackgroundColor="{StaticResource BgCard}" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderCard}" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="3. Cash Liya (Driver ke paas)" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="Total cash collected by driver" TextColor="{StaticResource Dim}" FontSize="10"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding TotalCashCollected, StringFormat='- ₹{0:N0}'}" TextColor="{StaticResource Red}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- STEP 4: Owner CNG Share -->
            <Border BackgroundColor="{StaticResource BgCard}" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderCard}" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="4. Owner CNG Share" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="CNG cost absorbed by Maalik" TextColor="{StaticResource Dim}" FontSize="10"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding OwnerCngShare, StringFormat='+ ₹{0:N0}'}" TextColor="{StaticResource Teal}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- STEP 5: Kharcha (Expenses) -->
            <Border BackgroundColor="{StaticResource BgCard}" StrokeShape="RoundRectangle 16" Stroke="{StaticResource BorderCard}" Padding="16">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="5. Kharcha (Reimbursement)" TextColor="{StaticResource White}" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="Toll + Parking + Other expenses" TextColor="{StaticResource Dim}" FontSize="10"/>
                    </VerticalStackLayout>
                    <Label Grid.Column="1" Text="{Binding TotalOwnerExpenses, StringFormat='+ ₹{0:N0}'}" TextColor="{StaticResource Teal}" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ③ Actions -->
            <!-- PRIMARY: Download PDF Receipt -->
            <Button Text="📄  Download Receipt (PDF)"
                    Command="{Binding DownloadPdfCommand}"
                    BackgroundColor="#1565C0" TextColor="White"
                    CornerRadius="14" HeightRequest="54"
                    FontSize="15" FontAttributes="Bold"
                    Margin="0,8,0,0"/>

            <!-- SECONDARY: Share text + Edit -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="📤 WhatsApp"
                        Command="{Binding ShareCommand}"
                        BackgroundColor="#25D366" TextColor="White"
                        CornerRadius="14" HeightRequest="50" FontAttributes="Bold"/>

                <Button Grid.Column="1" Text="✏️ Edit"
                        Command="{Binding EditCommand}"
                        BackgroundColor="#0D47A1" TextColor="White"
                        CornerRadius="14" HeightRequest="50" FontAttributes="Bold"/>
            </Grid>

            <Button Text="🗑  Delete Record"
                    Command="{Binding DeleteCommand}"
                    BackgroundColor="Transparent" TextColor="#EF5350"
                    BorderColor="#EF5350" BorderWidth="1"
                    CornerRadius="14" HeightRequest="48" Margin="0,4,0,0"/>

            <!-- ④ Audit History Drawer (Phase 7) -->
            <Button Text="{Binding HistoryToggleLabel}"
                    Command="{Binding ShowHistoryCommand}"
                    BackgroundColor="Transparent" TextColor="#566A7F"
                    BorderColor="#1A3560" BorderWidth="1"
                    CornerRadius="14" HeightRequest="44" Margin="0,4,0,0"
                    FontSize="13"/>

            <VerticalStackLayout IsVisible="{Binding IsHistoryVisible}" Spacing="8">
                <Label Text="EDIT HISTORY" TextColor="#566A7F" FontSize="11"
                       FontAttributes="Bold" Margin="4,4,0,0"/>

                <CollectionView ItemsSource="{Binding AuditHistory}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="No history recorded yet — future edits will appear here."
                               TextColor="#3A5570" FontSize="12" Margin="4,4"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AuditLogDisplay">
                            <Border BackgroundColor="#0A1220" StrokeShape="RoundRectangle 10"
                                    Stroke="#161F30" Padding="12,10" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="{Binding ActionIcon}"
                                           FontSize="16" VerticalOptions="Start" Margin="0,2,0,0"/>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding ActionLabel}"
                                                   TextColor="{Binding ActionColor}"
                                                   FontSize="12" FontAttributes="Bold"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding DateDisplay}"
                                                   TextColor="#566A7F" FontSize="10"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                        <Label Text="{Binding ChangeSummary}"
                                               TextColor="#78909C" FontSize="11"
                                               LineBreakMode="WordWrap"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
