<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DriverLedger.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" Title="{Binding Title}" BackgroundColor="#0D1B2A" Shell.NavBarIsVisible="True">

    <Shell.TitleView>
        <Label Text="⚙️  Settings" TextColor="White" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- ── Appearance ───────────────────────────────────────── -->
            <Label Text="APPEARANCE" TextColor="#4A6FA5" FontSize="11" FontAttributes="Bold" Margin="4,8,0,0"/>

            <Border BackgroundColor="#162032" StrokeShape="RoundRectangle 14" Stroke="#1E3A5F" Padding="20,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Label Grid.Column="0" Text="🌙" FontSize="22" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Dark Mode" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                        <Label Text="Toggle between dark and light theme" TextColor="#4A6FA5" FontSize="12"/>
                    </VerticalStackLayout>
                    <Switch Grid.Column="2" IsToggled="{Binding IsDarkMode}" OnColor="#2979FF" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ── Data Management ──────────────────────────────────── -->
            <Label Text="DATA MANAGEMENT" TextColor="#4A6FA5" FontSize="11" FontAttributes="Bold" Margin="4,8,0,0"/>

            <!-- Backup -->
            <Border BackgroundColor="#162032" StrokeShape="RoundRectangle 14" Stroke="#1E3A5F" Padding="20,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Label Grid.Column="0" Text="☁️" FontSize="22" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Backup Database" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                        <Label Text="Export your data as a .db file" TextColor="#4A6FA5" FontSize="12"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="Export" Command="{Binding BackupCommand}" IsEnabled="{Binding IsNotBusy}" BackgroundColor="#2979FF" TextColor="White" CornerRadius="8" HeightRequest="36" Padding="14,0" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Restore -->
            <Border BackgroundColor="#162032" StrokeShape="RoundRectangle 14" Stroke="#1E3A5F" Padding="20,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Label Grid.Column="0" Text="📂" FontSize="22" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Restore Database" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                        <Label Text="Import a previous .db backup file" TextColor="#4A6FA5" FontSize="12"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="Import" Command="{Binding RestoreCommand}" IsEnabled="{Binding IsNotBusy}" BackgroundColor="#1E3A5F" TextColor="#90CAF9" BorderColor="#2979FF" BorderWidth="1" CornerRadius="8" HeightRequest="36" Padding="14,0" FontSize="13" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- ── Account ──────────────────────────────────────────── -->
            <Label Text="ACCOUNT" TextColor="#4A6FA5" FontSize="11" FontAttributes="Bold" Margin="4,8,0,0"/>

            <Border BackgroundColor="#162032" StrokeShape="RoundRectangle 14" Stroke="#2A1010" Padding="20,16">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Label Grid.Column="0" Text="🔒" FontSize="22" VerticalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Logout" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                        <Label Text="Clear session and return to login" TextColor="#4A6FA5" FontSize="12"/>
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="Logout"
                            Command="{Binding LogoutCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="#C62828" TextColor="White"
                            CornerRadius="8" HeightRequest="36"
                            Padding="14,0" FontSize="13"
                            FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>
            </Border>

            <!-- Activity Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#2979FF" HorizontalOptions="Center" Margin="0,8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
