<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="DriverLedger.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#0D1B2A">

    <ContentPage.Resources>
        <Style x:Key="FieldLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextColor" Value="#90A4AE"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ErrorLabel" TargetType="Label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextColor" Value="#FF5252"/>
            <Setter Property="Margin" Value="4,2,0,0"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto" MinimumHeightRequest="600">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnPageTapped"/>
            </Grid.GestureRecognizers>

            <!-- ── Hero Header ────────────────────────────────────────── -->
            <Grid Grid.Row="0" Padding="32,60,32,44">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D1B2A" Offset="0.0"/>
                        <GradientStop Color="#1A2C3D" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="🚖" FontSize="60" HorizontalOptions="Center"/>
                    <Label HorizontalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Driver" TextColor="White"   FontSize="36" FontAttributes="Bold"/>
                                <Span Text="Ledger" TextColor="#2979FF" FontSize="36" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label Text="Fleet Accounting Made Easy"
                           FontSize="14" TextColor="#90A4AE"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ── Login Card ─────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    BackgroundColor="#1A2C3D"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#243447"
                    StrokeThickness="1"
                    Padding="24"
                    Margin="20,0,20,24">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.35"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">

                    <Label Text="Sign In" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="Enter your registered mobile number and password."
                           FontSize="13" TextColor="#90A4AE"/>

                    <!-- Lockout warning -->
                    <Border BackgroundColor="#3A1A1A"
                            StrokeShape="RoundRectangle 8"
                            Stroke="#FF5252"
                            StrokeThickness="1"
                            Padding="12,8"
                            IsVisible="{Binding IsLockedOut}">
                        <Label Text="{Binding LockoutMessage}"
                               FontSize="13" TextColor="#FF5252"
                               HorizontalOptions="Center"/>
                    </Border>

                    <!-- General login error -->
                    <Label Text="{Binding LoginError}"
                           Style="{StaticResource ErrorLabel}"
                           IsVisible="{Binding HasLoginError}"
                           HorizontalOptions="Center"/>

                    <!-- Mobile Number -->
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Mobile Number" Style="{StaticResource FieldLabel}"/>
                        <Border BackgroundColor="#243447" StrokeShape="RoundRectangle 10"
                                Stroke="#2979FF" StrokeThickness="1" Padding="14,0">
                            <Entry x:Name="EntryMobile"
                                   Text="{Binding MobileNumber}"
                                   Placeholder="+91 9999 999999"
                                   PlaceholderColor="#90A4AE"
                                   TextColor="White"
                                   Keyboard="Telephone"
                                   ReturnType="Next"
                                   HeightRequest="52"
                                   BackgroundColor="Transparent"
                                   ReturnCommand="{Binding FocusPasswordCommand}"/>
                        </Border>
                        <Label Text="{Binding MobileError}"
                               Style="{StaticResource ErrorLabel}"
                               IsVisible="{Binding HasMobileError}"/>
                    </VerticalStackLayout>

                    <!-- Password with show/hide toggle -->
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Password" Style="{StaticResource FieldLabel}"/>
                        <Border BackgroundColor="#243447" StrokeShape="RoundRectangle 10"
                                Stroke="#2979FF" StrokeThickness="1" Padding="14,0">
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry x:Name="EntryPassword"
                                       Grid.Column="0"
                                       Text="{Binding Password}"
                                       Placeholder="Your password"
                                       PlaceholderColor="#90A4AE"
                                       TextColor="White"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       ReturnType="Done"
                                       HeightRequest="52"
                                       BackgroundColor="Transparent"
                                       ReturnCommand="{Binding LoginCommand}"/>
                                <Button Grid.Column="1"
                                        Text="{Binding PasswordToggleIcon}"
                                        Command="{Binding TogglePasswordCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="#90A4AE"
                                        FontSize="18"
                                        WidthRequest="44"
                                        HeightRequest="44"
                                        Padding="0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <Label Text="{Binding PasswordError}"
                               Style="{StaticResource ErrorLabel}"
                               IsVisible="{Binding HasPasswordError}"/>
                    </VerticalStackLayout>

                    <!-- Forgot Password link -->
                    <Label Text="Forgot Password?"
                           FontSize="13"
                           TextColor="#2979FF"
                           HorizontalOptions="End">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Login Button -->
                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding CanLogin}"
                            HeightRequest="52"
                            FontSize="16"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            TextColor="White"
                            BackgroundColor="#2979FF"
                            Margin="0,4,0,0"/>

                    <!-- Activity Indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#2979FF"
                                       HorizontalOptions="Center"/>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" BackgroundColor="#243447" Margin="0,4"/>

                    <!-- Create Company outlined button -->
                    <Button Text="Create Company"
                            Command="{Binding CreateCompanyCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="48"
                            FontSize="14"
                            TextColor="#90A4AE"
                            BackgroundColor="Transparent"
                            BorderColor="#37474F"
                            BorderWidth="1"
                            CornerRadius="10"/>

                </VerticalStackLayout>
            </Border>

            <!-- ── Footer ─────────────────────────────────────────────── -->
            <VerticalStackLayout Grid.Row="2" Spacing="4"
                                 HorizontalOptions="Center"
                                 Margin="0,0,0,28">
                <Label Text="{Binding AppVersion}"
                       FontSize="12" TextColor="#37474F"
                       HorizontalOptions="Center"/>
                <Label Text="Offline • Secure • Fast"
                       FontSize="11" TextColor="#263238"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>

</ContentPage>
